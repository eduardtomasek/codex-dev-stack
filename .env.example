# Absolute path recommended.
PROJECTS_DIR=/absolute/path/to/your/projects
TZ=Europe/Prague

# Options: codex-login | openai | openrouter | ollama
LLM_PROVIDER=codex-login

# Optional agentmemory wiring for Codex/OpenCode
AGENTMEMORY_ENABLED=0
AGENTMEMORY_III_VERSION=0.11.2
AGENTMEMORY_BASE_URL=http://host.docker.internal:3211
AGENTMEMORY_STREAM_URL=ws://host.docker.internal:3212
AGENTMEMORY_VIEWER_URL=http://host.docker.internal:3213
AGENTMEMORY_SECRET=

# OpenAI / Codex API key mode
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.1-codex-max

# OpenRouter mode
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Ollama on host
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=qwen2.5-coder:32b

# GrepAI embeddings
GREPAI_EMBEDDER=ollama
GREPAI_EMBED_MODEL=nomic-embed-text-v2-moe
GREPAI_EMBED_ENDPOINT=http://host.docker.internal:11434
GREPAI_EMBED_DIMENSIONS=768

# Optional git defaults inside container
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=
GIT_COMMITTER_NAME=
GIT_COMMITTER_EMAIL=
